SUPABASE_URL="https://ytuzhqypnfkcptetvadl.supabase.co"
# Service role key (NO exponer en frontend ni en repositorios públicos)
SUPABASE_SERVICE_ROLE_KEY="<TU_SERVICE_ROLE_KEY_AQUI>"
# (Opcional) Publishable anon key (solo si lo necesitas en backend)
SUPABASE_ANON_KEY="<TU_ANON_KEY_AQUI>"

# Puerto donde corre el backend (coincidir con frontend VITE_BACKEND_API_URL)
PORT=4000

# Instrucciones: copia este archivo a `.env` y reemplaza los placeholders
# Luego desde la carpeta `backend` ejecuta `npm run dev` para reiniciar el servidor.